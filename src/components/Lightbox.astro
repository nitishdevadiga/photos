---
import { Image } from 'astro:assets';
import { photos } from '../data/photos.ts';
---

<dialog id="lightbox" class="lightbox" aria-label="Photo viewer">
  <button class="close" id="lb-close" aria-label="Close">×</button>

  <div class="stage">
    {
      photos.map((p) => (
        <figure class="frame" data-id={p.id} aria-hidden="true">
          <Image
            src={p.src}
            alt={p.title}
            widths={[800, 1200, 1800]}
            sizes="90vw"
            loading="lazy"
            format="webp"
            quality={90}
          />
          <figcaption>
            <span class="num">No. {p.id}</span>
            <span class="title">{p.title}</span>
            <span class="caption-text">{p.caption}</span>
            <span class="moods">
              {p.moods.map((m) => (
                <span>{m}</span>
              ))}
            </span>
          </figcaption>
        </figure>
      ))
    }
  </div>

  <button class="nav prev" id="lb-prev" aria-label="Previous">←</button>
  <button class="nav next" id="lb-next" aria-label="Next">→</button>
  <div class="counter mono" id="lb-counter"></div>
</dialog>

<style lang="scss">
  @use '../styles/tokens' as *;

  .lightbox {
    border: none;
    padding: 0;
    margin: 0;
    width: 100vw;
    height: 100vh;
    max-width: 100vw;
    max-height: 100vh;
    background: rgba(10, 8, 7, 0.97);
    backdrop-filter: blur(20px);
    color: $bone;
    overflow: hidden;

    &::backdrop {
      background: rgba(10, 8, 7, 0.97);
    }

    &[open] {
      display: flex;
      align-items: center;
      justify-content: center;
      animation: fadeIn $dur-base $ease forwards;
    }
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .stage {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .frame {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: $s-8 $s-7;
    opacity: 0;
    pointer-events: none;
    transition: opacity $dur-base $ease;

    &.is-active {
      opacity: 1;
      pointer-events: auto;
    }

    :global(img) {
      max-width: min(90vw, 1100px);
      max-height: 75vh;
      width: auto;
      height: auto;
      object-fit: contain;
      box-shadow: 0 30px 80px rgba(0, 0, 0, 0.6);
    }

    figcaption {
      margin-top: $s-5;
      text-align: center;
      display: flex;
      flex-direction: column;
      gap: $s-2;
      max-width: 600px;

      .num {
        font-family: $mono;
        font-size: 10px;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: $bone-mute;
      }
      .title {
        font-family: $serif;
        font-size: 28px;
        font-style: italic;
        font-weight: 300;
        letter-spacing: -0.01em;
        color: $bone;
      }
      .caption-text {
        font-family: $serif;
        font-size: 15px;
        color: $bone-soft;
      }
      .moods {
        display: flex;
        gap: $s-3;
        justify-content: center;
        margin-top: $s-2;
        font-family: $mono;
        font-size: 9px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: $rust;
      }
    }
  }

  .close {
    position: fixed;
    top: $s-5;
    right: $s-5;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid $ink-3;
    background: rgba(21, 17, 14, 0.6);
    color: $bone;
    font-size: 22px;
    line-height: 1;
    transition: all $dur-fast $ease;
    z-index: 2;

    &:hover {
      border-color: $rust;
      color: $rust;
    }
  }

  .nav {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid $ink-3;
    background: rgba(21, 17, 14, 0.6);
    color: $bone;
    font-size: 18px;
    line-height: 1;
    transition: all $dur-fast $ease;
    z-index: 2;

    &.prev {
      left: $s-5;
    }
    &.next {
      right: $s-5;
    }

    &:hover {
      border-color: $rust;
      color: $rust;
    }
  }

  .counter {
    position: fixed;
    bottom: $s-5;
    left: 50%;
    transform: translateX(-50%);
    color: $bone-mute;
    z-index: 2;
  }

  @include mobile {
    .frame {
      padding: $s-6 $s-3;
      :global(img) {
        max-height: 60vh;
      }
      figcaption .title {
        font-size: 22px;
      }
    }
    .nav {
      width: 40px;
      height: 40px;
      &.prev {
        left: $s-3;
      }
      &.next {
        right: $s-3;
      }
    }
  }
</style>
