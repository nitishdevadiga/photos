---
import { Image } from 'astro:assets';
import { photos } from '../data/photos.ts';

// Hero photo — pick the rose for opening drama (dark, mysterious)
const heroPhoto = photos.find((p) => p.id === '09')!;
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-text">
      <p class="eyebrow">Photographs · 2024 — 2025</p>
      <h1>
        <span class="line">Light, held</span>
        <span class="line"><em>briefly.</em></span>
      </h1>
      <p class="lede">
        A field journal by <strong>Nitish Devadiga</strong> — quiet macro,
        burning landscapes, dark rooms, and a few things that asked to be
        photographed before disappearing.
      </p>
      <div class="meta">
        <div>
          <span class="num">23</span>
          <span class="lbl">photographs</span>
        </div>
        <div>
          <span class="num">06</span>
          <span class="lbl">moods</span>
        </div>
        <div>
          <span class="num">02</span>
          <span class="lbl">years</span>
        </div>
      </div>
    </div>

    <figure class="hero-photo">
      <Image
        src={heroPhoto.src}
        alt={heroPhoto.title}
        widths={[480, 800, 1200]}
        sizes="(max-width: 900px) 100vw, 50vw"
        loading="eager"
        format="webp"
        quality={85}
      />
      <figcaption>
        <span class="mono">No. {heroPhoto.id}</span>
        <span class="title"><em>{heroPhoto.title}</em></span>
      </figcaption>
    </figure>
  </div>
</section>

<style lang="scss">
  @use '../styles/tokens' as *;

  .hero {
    padding-top: calc(#{$s-10} + #{$s-6});
    padding-bottom: $s-9;
    position: relative;

    &::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: $gutter;
      right: $gutter;
      height: 1px;
      background: linear-gradient(to right, transparent, $ink-3 20%, $ink-3 80%, transparent);
    }
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: $s-9;
    align-items: center;

    @include mobile {
      grid-template-columns: 1fr;
      gap: $s-7;
    }
  }

  .hero-text {
    .eyebrow {
      margin-bottom: $s-6;
    }
  }

  h1 {
    font-family: $serif;
    font-size: clamp(56px, 9vw, 132px);
    font-weight: 300;
    line-height: 0.92;
    letter-spacing: -0.035em;
    margin-bottom: $s-6;

    .line {
      display: block;
      opacity: 0;
      transform: translateY(20px);
      animation: rise $dur-slow $ease-out forwards;

      &:nth-child(1) {
        animation-delay: 0.1s;
      }
      &:nth-child(2) {
        animation-delay: 0.25s;
      }
    }

    em {
      font-style: italic;
      font-weight: 400;
      color: $rust;
    }
  }

  @keyframes rise {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .lede {
    font-size: 18px;
    line-height: 1.6;
    color: $bone-soft;
    max-width: 480px;
    margin-bottom: $s-7;

    strong {
      font-weight: 400;
      color: $bone;
    }
  }

  .meta {
    display: flex;
    gap: $s-7;

    @include mobile {
      gap: $s-5;
    }

    div {
      display: flex;
      flex-direction: column;
      gap: $s-1;
    }

    .num {
      font-family: $serif;
      font-size: 28px;
      font-weight: 300;
      color: $bone;
      letter-spacing: -0.02em;
    }

    .lbl {
      font-family: $mono;
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: $bone-mute;
    }
  }

  .hero-photo {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;

    :global(img) {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: brightness(0.95) contrast(1.05);
    }

    figcaption {
      position: absolute;
      bottom: $s-4;
      left: $s-4;
      right: $s-4;
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      color: $bone;
      text-shadow: 0 2px 12px rgba(0, 0, 0, 0.6);

      .mono {
        font-family: $mono;
        font-size: 10px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: $bone-soft;
      }

      .title {
        font-family: $serif;
        font-size: 18px;
        em {
          font-style: italic;
        }
      }
    }
  }
</style>
