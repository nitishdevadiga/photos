---
import { Image } from 'astro:assets';
import { photos } from '../data/photos.ts';

// Pick the photos that anchor each fragment of the collage.
// All references are by id so reordering data/photos.ts won't break the hero.
const get = (id: string) => {
  const p = photos.find((x) => x.id === id);
  if (!p) throw new Error(`Hero collage: photo id ${id} not found`);
  return p;
};

const fragBase    = get('15'); // big anchor — sunset daisies, color, warm
const fragAnt     = get('05'); // overlapping slab — ant macro, B&W
const fragRose    = get('09'); // small color inset — rose
const fragFire    = get('19'); // left slab — burning landscape
const fragLeaves  = get('14'); // bottom strip — backlit leaves
const fragFeather = get('16'); // top-left small — feather (already mono)
const fragDroplet = get('24'); // small circle — droplet on leaf
const fragPattern = get('11'); // tiny accent — pattern
---

<section class="hero">
  <!-- ============== COLLAGE STAGE ============== -->
  <div class="stage" aria-hidden="false">

    <!-- Base: big sunset daisies, color, anchors center -->
    <div class="frag frag-base" data-rise="1">
      <Image
        src={fragBase.src}
        alt={fragBase.title}
        widths={[400, 600, 800]}
        sizes="(max-width: 900px) 60vw, 340px"
        loading="eager"
        format="webp"
        quality={88}
      />
    </div>

    <!-- B&W ant slab — pushes into right side of base -->
    <div class="frag frag-ant" data-rise="2">
      <Image
        src={fragAnt.src}
        alt={fragAnt.title}
        widths={[300, 500]}
        sizes="200px"
        loading="eager"
        format="webp"
        quality={86}
      />
    </div>

    <!-- Color rose inset — sits on top-right of ant -->
    <div class="frag frag-rose" data-rise="3">
      <Image
        src={fragRose.src}
        alt={fragRose.title}
        widths={[200, 350]}
        sizes="140px"
        loading="eager"
        format="webp"
        quality={85}
      />
    </div>

    <!-- Fire/orange — left slab pushing into base -->
    <div class="frag frag-fire" data-rise="2">
      <Image
        src={fragFire.src}
        alt={fragFire.title}
        widths={[250, 400]}
        sizes="180px"
        loading="eager"
        format="webp"
        quality={86}
      />
      <span class="frag-label frag-label--diff">19 · fire</span>
    </div>

    <!-- Leaves strip — pushes UP from bottom into base -->
    <div class="frag frag-leaves" data-rise="3">
      <Image
        src={fragLeaves.src}
        alt={fragLeaves.title}
        widths={[200, 350]}
        sizes="150px"
        loading="lazy"
        format="webp"
        quality={85}
      />
      <span class="frag-label">14 · leaves</span>
    </div>

    <!-- Feather — small top-left, slight rotate -->
    <div class="frag frag-feather" data-rise="2">
      <Image
        src={fragFeather.src}
        alt={fragFeather.title}
        widths={[180, 300]}
        sizes="120px"
        loading="lazy"
        format="webp"
        quality={84}
      />
    </div>

    <!-- Droplet — small circular crop, pressed into ant's bottom-right -->
    <div class="frag frag-droplet" data-rise="4">
      <Image
        src={fragDroplet.src}
        alt={fragDroplet.title}
        widths={[150, 250]}
        sizes="90px"
        loading="lazy"
        format="webp"
        quality={84}
      />
    </div>

    <!-- Pattern — small slab pressed below fire, slight rotate -->
    <div class="frag frag-pattern" data-rise="4">
      <Image
        src={fragPattern.src}
        alt={fragPattern.title}
        widths={[150, 250]}
        sizes="110px"
        loading="lazy"
        format="webp"
        quality={84}
      />
    </div>

    <!-- Solid rust block with "briefly" — design element -->
    <div class="frag frag-rust" data-rise="3">
      <span><em>briefly</em></span>
    </div>

    <!-- Yellow circle — "23 photographs" stat fragment -->
    <div class="frag frag-circle" data-rise="3">
      <div class="circle-num">23</div>
      <div class="circle-lbl">photographs</div>
    </div>

    <!-- Barcode sticker — yellow, pressed below circle -->
    <div class="frag frag-barcode" data-rise="4">
      <div class="bars" aria-hidden="true"></div>
      <span class="bc-text">FIELD-25 · 2024—2025</span>
    </div>

    <!-- Quote card — translucent, pressed against ant's right -->
    <div class="frag frag-quote" data-rise="3">
      <span class="quote-eyebrow">No. 15 · index</span>
      <p class="quote-body"><em>"What grows through the burning."</em></p>
      <span class="quote-foot">2024 — 2025</span>
    </div>

  </div>

  <!-- ============== TYPE OVERLAY ============== -->
  <!-- Title: top-left, partially adjacent to the collage -->
  <div class="hero-title">
    <p class="eyebrow">Photographs · 2024 — 2025</p>
    <h1>
      <span class="line">Light,</span>
      <span class="line">held</span>
      <span class="line"><em>briefly.</em></span>
    </h1>
  </div>

  <!-- Lede + CTA: top-right, pressed against the collage's right edge -->
  <div class="hero-lede">
    <p>
      A field journal by <strong>Nitish Devadiga</strong> — twenty-three frames
      pulled from two years of looking, arranged by mood.
    </p>
    <a class="scroll-cue" href="#featured">
      <span>Begin</span>
      <span class="arrow">↓</span>
    </a>
  </div>

  <!-- Stat strap across the bottom -->
  <div class="hero-strap">
    <div class="stats">
      <div><span class="lbl">moods</span><span class="num">07</span></div>
      <div><span class="lbl">years</span><span class="num">02</span></div>
      <div><span class="lbl">featured</span><span class="num">{photos.filter(p => p.featured).length.toString().padStart(2,'0')}</span></div>
    </div>
    <span class="strap-meta">A field journal · No. 15 / {photos.length}</span>
  </div>
</section>

<style lang="scss">
  @use '../styles/tokens' as *;

  // ============================================================
  // SECTION SHELL
  // ============================================================
  .hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    overflow: hidden;
    background: $ink;
    padding: $s-9 0 $s-7;

    @include mobile {
      min-height: auto;
      padding: $s-7 0 $s-6;
    }
  }

  // ============================================================
  // COLLAGE STAGE — fixed-canvas centered, fragments positioned absolutely
  // The stage is a defined area within the hero so percentages stay coherent.
  // ============================================================
  .stage {
    position: relative;
    width: min(960px, calc(100% - #{$s-6} * 2));
    margin: 0 auto;
    aspect-ratio: 960 / 720;
    pointer-events: none; // type sits above; collage is decorative

    @include mobile {
      aspect-ratio: 360 / 480;
      margin-bottom: $s-5;
    }
  }

  .frag {
    position: absolute;
    overflow: hidden;
    will-change: transform, opacity;
    opacity: 0;
    transform: translateY(24px);
    animation: fragRise 1.1s $ease-out forwards;

    // Cascade rise order via data-rise=1..4
    &[data-rise='1'] { animation-delay: 0.05s; }
    &[data-rise='2'] { animation-delay: 0.18s; }
    &[data-rise='3'] { animation-delay: 0.30s; }
    &[data-rise='4'] { animation-delay: 0.42s; }

    :global(img) {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      display: block;
    }
  }

  @keyframes fragRise {
    to { opacity: 1; transform: translateY(0); }
  }

  // Per-fragment positions, sizes, z-orders.
  // Percentages are against the .stage box, so the whole composition
  // scales together rather than drifting apart on different viewports.

  // 1) BASE: big sunset daisies — center anchor
  .frag-base {
    left: 32%;
    top: 18%;
    width: 38%;
    height: 62%;
    z-index: 2;
    box-shadow: 0 1px 0 rgba(237,229,216,0.08), 0 24px 60px rgba(0,0,0,0.7);
  }

  // 2) ANT (B&W) — overlaps right side of base by ~6%
  .frag-ant {
    left: 56%;
    top: 12%;
    width: 22%;
    height: 42%;
    z-index: 5;
    box-shadow: 0 1px 0 rgba(237,229,216,0.08), 0 16px 40px rgba(0,0,0,0.65);
    :global(img) {
      filter: grayscale(1) contrast(1.12) brightness(0.92);
    }
  }

  // 3) ROSE — sits ON TOP of ant's top-right corner, kisses the rust block
  .frag-rose {
    left: 62%;
    top: 8%;
    width: 16%;
    height: 14%;
    z-index: 7;
    box-shadow: 0 1px 0 rgba(237,229,216,0.08), 0 14px 32px rgba(0,0,0,0.6);
  }

  // 4) FIRE — overlaps base's LEFT side by ~6% (used to be a gap)
  .frag-fire {
    left: 26%;
    top: 36%;
    width: 19%;
    height: 28%;
    z-index: 6;
    box-shadow: 0 1px 0 rgba(237,229,216,0.08), 0 14px 32px rgba(0,0,0,0.6);
  }

  // 5) LEAVES — pushes up from bottom into base, overlap by ~8%
  .frag-leaves {
    left: 40%;
    top: 60%;
    width: 16%;
    height: 30%;
    z-index: 8;
    box-shadow: 0 -1px 0 rgba(237,229,216,0.08), 0 -8px 28px rgba(0,0,0,0.55);
  }

  // 6) FEATHER — top-left small, rotated, kisses fire's top
  .frag-feather {
    left: 19%;
    top: 24%;
    width: 13%;
    height: 19%;
    z-index: 4;
    box-shadow: 0 1px 0 rgba(237,229,216,0.08), 0 12px 28px rgba(0,0,0,0.55);
    transform-origin: center;
    transform: rotate(-3deg);
    animation-name: fragRiseRotate1;
  }
  @keyframes fragRiseRotate1 {
    from { opacity: 0; transform: rotate(-3deg) translateY(24px); }
    to   { opacity: 1; transform: rotate(-3deg) translateY(0); }
  }

  // 7) DROPLET — small circle, OVERLAPS ant's bottom-right corner
  .frag-droplet {
    left: 67%;
    top: 46%;
    width: 10%;
    height: 13%;
    z-index: 9;
    border-radius: 50%;
    box-shadow: 0 1px 0 rgba(237,229,216,0.1), 0 8px 22px rgba(0,0,0,0.55);
  }

  // 8) PATTERN — small slab below fire, rotated, kisses circle's left
  .frag-pattern {
    left: 17%;
    top: 70%;
    width: 12%;
    height: 14%;
    z-index: 7;
    box-shadow: 0 1px 0 rgba(237,229,216,0.08), 0 8px 22px rgba(0,0,0,0.5);
    transform: rotate(2deg);
    animation-name: fragRiseRotate2;
  }
  @keyframes fragRiseRotate2 {
    from { opacity: 0; transform: rotate(2deg) translateY(24px); }
    to   { opacity: 1; transform: rotate(2deg) translateY(0); }
  }

  // 9) RUST — solid block, pressed into right of ant
  .frag-rust {
    left: 76%;
    top: 36%;
    width: 14%;
    height: 11%;
    z-index: 9;
    background: $rust;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 1px 0 rgba(237,229,216,0.1), 0 10px 24px rgba(0,0,0,0.5);
    span {
      font-family: $serif;
      font-size: clamp(18px, 2vw, 26px);
      color: $ink;
      letter-spacing: -0.02em;
      em { font-style: italic; }
    }
  }

  // 10) YELLOW CIRCLE — overlaps fire's left edge AND leaves
  .frag-circle {
    left: 13%;
    top: 56%;
    width: 17%;
    height: 22%;
    z-index: 10;
    border-radius: 50%;
    background: #e8c44a;
    color: $ink;
    box-shadow: 0 1px 0 rgba(237,229,216,0.12), 0 14px 32px rgba(0,0,0,0.45);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;

    .circle-num {
      font-family: $serif;
      font-size: clamp(28px, 3.6vw, 44px);
      font-weight: 300;
      letter-spacing: -0.02em;
      line-height: 1;
    }
    .circle-lbl {
      font-family: $mono;
      font-size: 9px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      opacity: 0.7;
      margin-top: 4px;
    }
  }

  // 11) BARCODE — pressed below the circle
  .frag-barcode {
    left: 28%;
    top: 78%;
    width: 17%;
    height: 8%;
    z-index: 11;
    background: #e8c44a;
    padding: 8px 12px;
    color: $ink;
    box-shadow: 0 1px 0 rgba(237,229,216,0.1), 0 8px 22px rgba(0,0,0,0.45);
    transform: rotate(-1.5deg);
    animation-name: fragRiseRotate3;

    .bars {
      height: 18px;
      background-image: repeating-linear-gradient(
        to right,
        $ink 0 2px, transparent 2px 3px,
        $ink 3px 4px, transparent 4px 7px,
        $ink 7px 10px, transparent 10px 11px,
        $ink 11px 12px, transparent 12px 14px,
        $ink 14px 17px, transparent 17px 18px
      );
    }
    .bc-text {
      display: block;
      font-family: $mono;
      font-size: 8px;
      letter-spacing: 0.12em;
      font-weight: 500;
      margin-top: 4px;
    }
  }
  @keyframes fragRiseRotate3 {
    from { opacity: 0; transform: rotate(-1.5deg) translateY(24px); }
    to   { opacity: 1; transform: rotate(-1.5deg) translateY(0); }
  }

  // 12) QUOTE CARD — translucent, pressed against right of ant
  .frag-quote {
    left: 81%;
    top: 14%;
    width: 17%;
    height: 22%;
    z-index: 12;
    background: rgba($bone, 0.08);
    border: 0.5px solid rgba($bone, 0.22);
    backdrop-filter: blur(8px);
    padding: $s-4;
    color: $bone;
    display: flex;
    flex-direction: column;

    .quote-eyebrow,
    .quote-foot {
      font-family: $mono;
      font-size: 9px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }
    .quote-eyebrow { opacity: 0.55; margin-bottom: $s-2; }
    .quote-foot    { opacity: 0.45; margin-top: auto; font-size: 8px; }
    .quote-body {
      font-family: $serif;
      font-size: clamp(11px, 1.3vw, 14px);
      line-height: 1.45;
      font-style: italic;
      opacity: 0.9;
      margin: 0;
    }
  }

  // ============================================================
  // FRAGMENT LABELS (small mono captions anchored inside fragments)
  // ============================================================
  .frag-label {
    position: absolute;
    bottom: 8px;
    right: 10px;
    color: $bone;
    opacity: 0.85;
    font-family: $mono;
    font-size: 9px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    pointer-events: none;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.6);
  }
  .frag-label--diff {
    top: 8px;
    left: 10px;
    bottom: auto;
    right: auto;
    mix-blend-mode: difference;
    text-shadow: none;
  }

  // ============================================================
  // TYPE OVERLAY
  // ============================================================
  .hero-title {
    position: absolute;
    top: $s-9;
    left: $s-6;
    max-width: 22rem;
    z-index: 20;
    pointer-events: none;

    @include mobile {
      position: static;
      max-width: 100%;
      padding: 0 $s-5;
      margin-bottom: $s-5;
    }

    .eyebrow {
      font-family: $mono;
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: $bone;
      opacity: 0.7;
      margin: 0 0 $s-4;
    }

    h1 {
      font-family: $serif;
      font-size: clamp(56px, 7.5vw, 96px);
      font-weight: 300;
      line-height: 0.9;
      letter-spacing: -0.04em;
      margin: 0;
      color: $bone;
      text-shadow: 0 4px 30px rgba(0, 0, 0, 0.85);

      .line {
        display: block;
        opacity: 0;
        transform: translateY(30px);
        animation: rise 1s $ease-out forwards;
        &:nth-child(1) { animation-delay: 0.1s; }
        &:nth-child(2) { animation-delay: 0.25s; }
        &:nth-child(3) { animation-delay: 0.4s; }
      }
      em {
        font-style: italic;
        font-weight: 400;
        color: $rust;
      }
    }
  }

  @keyframes rise {
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-lede {
    position: absolute;
    top: 56%;
    right: $s-6;
    width: 15rem;
    z-index: 20;
    opacity: 0;
    animation: fadeIn 1s $ease-out 0.7s forwards;

    @include mobile {
      position: static;
      width: 100%;
      padding: 0 $s-5;
      margin: $s-5 0;
    }

    p {
      font-size: 14px;
      line-height: 1.6;
      color: $bone;
      opacity: 0.88;
      margin: 0 0 $s-5;
      text-shadow: 0 2px 16px rgba(0, 0, 0, 0.85);

      strong { font-weight: 400; color: $bone; }
    }
  }

  @keyframes fadeIn {
    to { opacity: 1; }
  }

  .scroll-cue {
    display: inline-flex;
    align-items: center;
    gap: $s-3;
    font-family: $mono;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: $bone;
    border: 1px solid rgba($bone, 0.35);
    padding: $s-3 $s-5;
    border-radius: 999px;
    background: rgba($ink, 0.4);
    backdrop-filter: blur(8px);
    transition: all $dur-base $ease;
    pointer-events: auto;

    .arrow { transition: transform $dur-base $ease; }

    &:hover {
      border-color: $rust;
      color: $rust;
      .arrow { transform: translateY(4px); }
    }
  }

  // ============================================================
  // BOTTOM STAT STRAP
  // ============================================================
  .hero-strap {
    position: absolute;
    left: $s-6;
    right: $s-6;
    bottom: $s-6;
    z-index: 20;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    border-top: 0.5px solid rgba($bone, 0.18);
    padding-top: $s-3;
    opacity: 0;
    animation: fadeIn 1s $ease-out 0.9s forwards;

    @include mobile {
      position: static;
      margin: $s-5 $s-5 0;
      flex-direction: column;
      gap: $s-4;
      align-items: flex-start;
    }

    .stats {
      display: flex;
      gap: $s-7;
      color: $bone;

      @include mobile { gap: $s-5; }

      div {
        display: flex;
        flex-direction: column;
        gap: 2px;
      }

      .lbl {
        font-family: $mono;
        font-size: 9px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        opacity: 0.55;
      }
      .num {
        font-family: $serif;
        font-size: 24px;
        font-weight: 300;
        letter-spacing: -0.02em;
      }
    }

    .strap-meta {
      font-family: $mono;
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: $bone;
      opacity: 0.5;
    }
  }

  // ============================================================
  // REDUCED MOTION
  // ============================================================
  @media (prefers-reduced-motion: reduce) {
    .frag, .hero-lede, .hero-strap, h1 .line {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
    .frag-feather  { transform: rotate(-3deg) !important; }
    .frag-pattern  { transform: rotate(2deg) !important; }
    .frag-barcode  { transform: rotate(-1.5deg) !important; }
  }
</style>
