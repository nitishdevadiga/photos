---
import { Image } from 'astro:assets';
import { photos } from '../data/photos.ts';

// The "paper" being torn (covers the whole hero): daisies on fire
const paperPhoto = photos.find((p) => p.id === '15')!;
// What's underneath, visible through the torn strip: ant photo (B&W)
const underPhoto = photos.find((p) => p.id === '05')!;
---

<section class="hero">
  <div class="hero-image">
    <!-- BOTTOM: ant photo, B&W, fills the entire hero. -->
    <!-- It only becomes visible inside the torn strip; everything else is covered by paper. -->
    <div class="under-layer">
      <Image
        src={underPhoto.src}
        alt={underPhoto.title}
        widths={[800, 1200, 1800]}
        sizes="100vw"
        loading="eager"
        format="webp"
        quality={88}
      />
    </div>

    <!-- TOP "paper" (daisies) with a horizontal strip torn out of the middle.
         Built as two halves: top piece + bottom piece, with empty space between. -->
    <div class="paper-top">
      <Image
        src={paperPhoto.src}
        alt=""
        widths={[800, 1200, 1800, 2400]}
        sizes="100vw"
        loading="eager"
        format="webp"
        quality={88}
      />
    </div>

    <div class="paper-bottom">
      <Image
        src={paperPhoto.src}
        alt=""
        widths={[800, 1200, 1800, 2400]}
        sizes="100vw"
        loading="eager"
        format="webp"
        quality={88}
      />
    </div>

    <!-- The torn deckle edges (SVG). Two ragged lines: one on top, one on bottom. -->
    <svg class="tear-edges" viewBox="0 0 1600 900" preserveAspectRatio="none" aria-hidden="true">
      <defs>
        <!-- Roughen filter: turbulence + displacement creates the fibrous deckle -->
        <filter id="deckle" x="-2%" y="-50%" width="104%" height="200%">
          <feTurbulence type="fractalNoise" baseFrequency="0.025 0.04" numOctaves="3" seed="7" />
          <feDisplacementMap in="SourceGraphic" scale="14" />
        </filter>
        <!-- Drop shadow under the upper torn edge (paper sitting on photo) -->
        <filter id="topShadow" x="-5%" y="0%" width="110%" height="300%">
          <feGaussianBlur in="SourceAlpha" stdDeviation="6" />
          <feOffset dx="0" dy="6" />
          <feFlood flood-color="#000" flood-opacity="0.6" />
          <feComposite in2="SourceAlpha" operator="in" />
          <feMerge>
            <feMergeNode />
            <feMergeNode in="SourceGraphic" />
          </feMerge>
        </filter>
        <!-- Inverted drop shadow for the bottom torn edge -->
        <filter id="bottomShadow" x="-5%" y="-200%" width="110%" height="300%">
          <feGaussianBlur in="SourceAlpha" stdDeviation="6" />
          <feOffset dx="0" dy="-6" />
          <feFlood flood-color="#000" flood-opacity="0.6" />
          <feComposite in2="SourceAlpha" operator="in" />
          <feMerge>
            <feMergeNode />
            <feMergeNode in="SourceGraphic" />
          </feMerge>
        </filter>
      </defs>

      <!-- Top edge — bone-white deckle line on bottom of upper paper piece -->
      <path class="edge-top" filter="url(#deckle)"
        d="M -10,425
           Q 80,432 160,418
           T 320,425
           T 480,420
           T 640,430
           T 800,418
           T 960,428
           T 1120,420
           T 1280,432
           T 1440,420
           T 1610,428
           L 1610,440 L -10,440 Z"
        fill="#ede5d8"
        opacity="0.92" />

      <!-- Bottom edge — bone-white deckle line on top of lower paper piece -->
      <path class="edge-bottom" filter="url(#deckle)"
        d="M -10,572
           Q 80,565 160,580
           T 320,575
           T 480,582
           T 640,572
           T 800,585
           T 960,575
           T 1120,582
           T 1280,570
           T 1440,580
           T 1610,572
           L 1610,558 L -10,558 Z"
        fill="#ede5d8"
        opacity="0.92" />
    </svg>

    <div class="vignette"></div>
  </div>

  <div class="hero-content">
    <div class="container">
      <p class="eyebrow">Photographs · 2024 — 2025</p>
      <h1>
        <span class="line">Light, held</span>
        <span class="line"><em>briefly.</em></span>
      </h1>
      <p class="lede">
        A field journal by <strong>Nitish Devadiga</strong> — quiet macro,
        burning landscapes, dark rooms, and a few things that asked to be
        photographed before disappearing.
      </p>

      <div class="hero-meta-row">
        <div class="meta">
          <div>
            <span class="num">23</span>
            <span class="lbl">photographs</span>
          </div>
          <div>
            <span class="num">07</span>
            <span class="lbl">moods</span>
          </div>
          <div>
            <span class="num">02</span>
            <span class="lbl">years</span>
          </div>
        </div>

        <a class="scroll-cue" href="#featured">
          <span>Begin</span>
          <span class="arrow">↓</span>
        </a>
      </div>
    </div>
  </div>

  <!-- attribution badge -->
  <div class="hero-credit">
    <span class="num">Through · No. {paperPhoto.id} / {underPhoto.id}</span>
    <span class="title"><em>What grows through the burning.</em></span>
  </div>
</section>

<style lang="scss">
  @use '../styles/tokens' as *;

  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 640px;
    overflow: hidden;
    background: $ink;
  }

  .hero-image {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  // BOTTOM: ant photo, B&W, no zoom, kept simple.
  // Visible only through the torn strip in the middle.
  .under-layer {
    position: absolute;
    inset: 0;
    z-index: 1;

    :global(img) {
      width: 100%;
      height: 100%;
      object-fit: cover;
      // Object-position pulls the ant up so it's visible through the middle strip
      object-position: center 40%;
      // Black & white treatment with strong contrast
      filter: grayscale(1) contrast(1.15) brightness(0.95);
      // No zoom, no animation. Simple, still.
    }
  }

  // TOP HALF of paper: daisies image, clipped to the upper region only,
  // ending at a ragged horizontal line ~47% down the screen.
  .paper-top {
    position: absolute;
    inset: 0;
    z-index: 2;
    // clip-path creates a ragged bottom edge with hand-tuned irregularity
    clip-path: polygon(
      0 0, 100% 0, 100% 0,
      // bottom edge — moves left to right with random vertical jitter
      100% 47%, 96% 48%, 92% 46%, 88% 49%, 84% 47%, 80% 48%,
      76% 46%, 72% 49%, 68% 47%, 64% 48%, 60% 46%, 56% 49%,
      52% 47%, 48% 49%, 44% 46%, 40% 48%, 36% 47%, 32% 49%,
      28% 46%, 24% 48%, 20% 47%, 16% 49%, 12% 46%, 8% 48%, 4% 47%, 0 48%
    );

    :global(img) {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      filter: saturate(1.05);
    }
  }

  // BOTTOM HALF of paper: daisies image, clipped to lower region only,
  // starting at a ragged horizontal line ~63% down the screen.
  .paper-bottom {
    position: absolute;
    inset: 0;
    z-index: 2;
    clip-path: polygon(
      0 64%, 4% 63%, 8% 65%, 12% 64%, 16% 62%, 20% 64%,
      24% 63%, 28% 65%, 32% 63%, 36% 64%, 40% 62%, 44% 64%,
      48% 63%, 52% 65%, 56% 62%, 60% 64%, 64% 63%, 68% 65%,
      72% 63%, 76% 64%, 80% 62%, 84% 64%, 88% 63%, 92% 65%,
      96% 63%, 100% 65%,
      100% 100%, 0 100%
    );

    :global(img) {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      filter: saturate(1.05);
    }
  }

  // SVG with the white deckle edges + drop shadows
  .tear-edges {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 3;
    pointer-events: none;
  }

  .vignette {
    position: absolute;
    inset: 0;
    z-index: 4;
    pointer-events: none;
    background:
      linear-gradient(to bottom, rgba(10, 8, 7, 0.85) 0%, rgba(10, 8, 7, 0.3) 22%, transparent 45%),
      linear-gradient(to top, rgba(10, 8, 7, 0.95) 0%, rgba(10, 8, 7, 0.7) 22%, transparent 55%),
      radial-gradient(ellipse at center, transparent 35%, rgba(10, 8, 7, 0.55) 100%);
  }

  .hero-content {
    position: absolute;
    inset: 0;
    z-index: 5;
    display: flex;
    align-items: flex-end;
    padding-bottom: $s-9;
    pointer-events: none;

    .container > * {
      pointer-events: auto;
    }
  }

  .eyebrow {
    margin-bottom: $s-5;
    color: $bone;
    opacity: 0.7;
  }

  h1 {
    font-family: $serif;
    font-size: clamp(64px, 11vw, 180px);
    font-weight: 300;
    line-height: 0.92;
    letter-spacing: -0.04em;
    margin-bottom: $s-5;
    color: $bone;
    max-width: 14ch;
    text-shadow: 0 4px 30px rgba(0, 0, 0, 0.7);

    .line {
      display: block;
      opacity: 0;
      transform: translateY(30px);
      animation: rise 1s $ease-out forwards;

      &:nth-child(1) {
        animation-delay: 0.15s;
      }
      &:nth-child(2) {
        animation-delay: 0.35s;
      }
    }

    em {
      font-style: italic;
      font-weight: 400;
      color: $rust;
    }
  }

  @keyframes rise {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .lede {
    font-size: 18px;
    line-height: 1.6;
    color: $bone;
    max-width: 540px;
    margin-bottom: $s-7;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.8);
    opacity: 0;
    animation: fadeIn 1s $ease-out 0.6s forwards;

    strong {
      font-weight: 400;
      color: $bone;
    }
  }

  @keyframes fadeIn {
    to {
      opacity: 0.9;
    }
  }

  .hero-meta-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: $s-6;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeIn 1s $ease-out 0.8s forwards;
  }

  .meta {
    display: flex;
    gap: $s-7;
    color: $bone;

    @include mobile {
      gap: $s-5;
    }

    div {
      display: flex;
      flex-direction: column;
      gap: $s-1;
    }

    .num {
      font-family: $serif;
      font-size: 32px;
      font-weight: 300;
      letter-spacing: -0.02em;
      text-shadow: 0 2px 10px rgba(0, 0, 0, 0.7);
    }

    .lbl {
      font-family: $mono;
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: $bone;
      opacity: 0.65;
    }
  }

  .scroll-cue {
    display: inline-flex;
    align-items: center;
    gap: $s-3;
    font-family: $mono;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: $bone;
    border: 1px solid rgba($bone, 0.3);
    padding: $s-3 $s-5;
    border-radius: 999px;
    transition: all $dur-base $ease;
    backdrop-filter: blur(8px);
    background: rgba(10, 8, 7, 0.3);

    .arrow {
      transition: transform $dur-base $ease;
    }

    &:hover {
      border-color: $rust;
      color: $rust;
      .arrow {
        transform: translateY(4px);
      }
    }
  }

  .hero-credit {
    position: absolute;
    top: 50%;
    right: $s-6;
    z-index: 5;
    transform: translateY(-50%) rotate(90deg);
    transform-origin: right center;
    display: flex;
    gap: $s-4;
    align-items: baseline;
    color: $bone;
    opacity: 0.55;

    .num {
      font-family: $mono;
      font-size: 10px;
      letter-spacing: 0.25em;
      text-transform: uppercase;
    }
    .title {
      font-family: $serif;
      font-size: 13px;
      em {
        font-style: italic;
      }
    }

    @include mobile {
      display: none;
    }
  }

  @include mobile {
    .hero {
      min-height: 100svh;
    }
    .hero-content {
      padding-bottom: $s-7;
    }
    .hero-meta-row {
      flex-direction: column;
      align-items: flex-start;
      gap: $s-4;
    }
  }
</style>
