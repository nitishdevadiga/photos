---
const facts = [
  { dt: 'Based', dd: 'Karnataka, India' },
  { dt: 'Working with', dd: 'Mobile + macro lens' },
  { dt: 'Subjects', dd: 'Macro · Land · Light' },
  { dt: 'Available for', dd: 'Prints · Editorial · Brand' },
];
---

<section id="about" class="about">
  <div class="container about-grid">
    <div>
      <p class="eyebrow">About</p>
      <h2>I photograph the <em>edge</em> of things.</h2>
      <p>
        I'm Nitish — a self-taught photographer drawn to small subjects, last
        light, and quiet rooms. Most of these were shot within a few feet of
        home, in the last hour before dark.
      </p>
      <p>
        I'm not loyal to one genre. A rose in shadow and a mountain at noon
        belong on the same wall if they share a feeling. This site is organized
        by mood for that reason.
      </p>

      <a class="cta" href="mailto:hello@nitishdevadiga.com">
        <span>Let's talk</span>
        <em>→</em>
      </a>
    </div>

    <dl class="facts">
      {
        facts.map((f) => (
          <div>
            <dt>{f.dt}</dt>
            <dd>{f.dd}</dd>
          </div>
        ))
      }
      <div>
        <dt>Elsewhere</dt>
        <dd>
          <a href="https://instagram.com/nitz.clicks" target="_blank" rel="noopener"
            >@nitz.clicks ↗</a
          >
        </dd>
      </div>
    </dl>
  </div>
</section>

<style lang="scss">
  @use '../styles/tokens' as *;

  .about {
    padding-top: $s-10;
    padding-bottom: $s-9;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: $s-9;

    @include mobile {
      grid-template-columns: 1fr;
      gap: $s-6;
    }
  }

  .eyebrow {
    margin-bottom: $s-4;
  }

  h2 {
    font-family: $serif;
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 300;
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin-bottom: $s-5;
    max-width: 14ch;

    em {
      font-style: italic;
      color: $rust;
    }
  }

  p {
    font-size: 18px;
    line-height: 1.65;
    color: $bone-soft;
    max-width: 56ch;
    margin-bottom: $s-4;
  }

  .cta {
    display: inline-flex;
    align-items: baseline;
    gap: $s-3;
    margin-top: $s-5;
    font-family: $serif;
    font-size: 28px;
    font-style: italic;
    font-weight: 300;
    color: $bone;
    border-bottom: 1px solid $ink-3;
    padding-bottom: $s-2;
    transition: color $dur-fast $ease, border-color $dur-fast $ease;

    em {
      font-style: normal;
      transition: transform $dur-base $ease;
    }

    &:hover {
      color: $rust;
      border-color: $rust;
      em {
        transform: translateX(6px);
      }
    }
  }

  .facts {
    display: grid;
    gap: $s-5;
    align-content: start;
    padding-top: $s-3;

    div {
      display: grid;
      gap: $s-1;
    }

    dt {
      font-family: $mono;
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: $bone-mute;
    }
    dd {
      font-family: $serif;
      font-size: 17px;
      color: $bone;

      a {
        transition: color $dur-fast $ease;
        &:hover {
          color: $rust;
        }
      }
    }
  }
</style>
