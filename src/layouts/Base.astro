---
import '../styles/global.scss';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Nitish Devadiga — clicks',
  description = 'Photographs by Nitish Devadiga. Quiet, burning, dark, wandering.',
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0807" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href={base || '/'} class="logo">
          <span>nitish</span>
          <em>devadiga</em>
        </a>
        <nav class="nav">
          <a href={`${base}#featured`}>Featured</a>
          <a href={`${base}#archive`}>Archive</a>
          <a href={`${base}#about`}>About</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div>© 2026 Nitish Devadiga</div>
        <div class="links">
          <a href="https://instagram.com/nitz.clicks" target="_blank" rel="noopener"
            >instagram ↗</a
          >
          <a href="https://github.com/nitishdevadiga" target="_blank" rel="noopener"
            >github ↗</a
          >
        </div>
      </div>
    </footer>

    <style lang="scss">
      @use '../styles/tokens' as *;

      .site-header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 50;
        padding: $s-5 0;
        background: linear-gradient(to bottom, $ink 60%, transparent);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
      }

      .header-inner {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
      }

      .logo {
        font-family: $serif;
        font-size: 16px;
        font-weight: 400;
        letter-spacing: -0.01em;
        color: $bone;

        em {
          font-style: italic;
          font-weight: 300;
          color: $bone-soft;
          margin-left: 0.25em;
        }
      }

      .nav {
        display: flex;
        gap: $s-6;
        font-family: $mono;
        font-size: 11px;
        letter-spacing: 0.18em;
        text-transform: uppercase;

        a {
          color: $bone-soft;
          position: relative;
          padding-bottom: 2px;
          transition: color $dur-fast $ease;

          &::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: $rust;
            transform: scaleX(0);
            transform-origin: right;
            transition: transform $dur-base $ease;
          }

          &:hover {
            color: $bone;
            &::after {
              transform: scaleX(1);
              transform-origin: left;
            }
          }
        }
      }

      @include mobile {
        .nav {
          gap: $s-4;
          font-size: 10px;
        }
      }

      .site-footer {
        margin-top: $s-10;
        padding: $s-6 0 $s-7;
        border-top: 1px solid $ink-3;
      }
      .footer-inner {
        display: flex;
        justify-content: space-between;
        font-family: $mono;
        font-size: 11px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: $bone-mute;
      }
      .links {
        display: flex;
        gap: $s-5;
        a {
          transition: color $dur-fast $ease;
          &:hover {
            color: $rust;
          }
        }
      }

      @include mobile {
        .footer-inner {
          flex-direction: column;
          gap: $s-3;
        }
      }
    </style>
  </body>
</html>
